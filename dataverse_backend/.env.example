# Backend runtime
ENVIRONMENT=production
APP_VERSION=1.0.0
ENABLE_OPENAPI_DOCS=false

# Logging
LOG_LEVEL=INFO
LOG_JSON=true
LOG_DIR=./logs

# Security
SECRET_KEY=change-me-with-a-strong-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS=https://your-frontend-domain.com
TRUSTED_HOSTS=your-api-domain.com
SECURE_HEADERS_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_PATH_PREFIX=/api

# Database and cache
DATABASE_URL=postgresql+asyncpg://dataverse:change-me@postgres:5432/dataverse
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Optional model providers
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.4
OPENAI_INTENT_MODEL=gpt-5-mini
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_INTENT_MODEL=deepseek-chat
TOGETHER_API_KEY=
GOOGLE_API_KEY=
HF_TOKEN=
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
