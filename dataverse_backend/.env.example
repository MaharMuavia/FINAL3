# Backend runtime
ENVIRONMENT=development
APP_VERSION=1.0.0
ENABLE_OPENAPI_DOCS=true

# Logging
LOG_LEVEL=INFO
LOG_JSON=false
LOG_DIR=./logs

# Security
SECRET_KEY=change-me-with-a-strong-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
TRUSTED_HOSTS=localhost,127.0.0.1,testserver
SECURE_HEADERS_ENABLED=true
RATE_LIMIT_ENABLED=false

# Optional database and cache (bypassed in MVP)
DATABASE_URL=
REDIS_URL=
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Prediction settings
AUTO_TRAIN_TARGET_CONFIDENCE=0.65
MIN_ROWS_FOR_PREDICTION=30

# Optional model providers (the analysis core runs deterministically without keys)
LLM_PROVIDER=auto
REPORT_NARRATOR_TIMEOUT_SECONDS=20
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_INTENT_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_REPORT_MODEL=gemini-1.5-pro
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20241022
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_INTENT_MODEL=deepseek-chat
GOOGLE_API_KEY=
SENTRY_DSN=
